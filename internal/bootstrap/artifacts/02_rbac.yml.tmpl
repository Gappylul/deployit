apiVersion: v1
kind: Namespace
metadata:
  name: deployit-system
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: webapp-operator
  namespace: deployit-system
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: webapp-operator
rules:
  - apiGroups: ["platform.gappy.hu"]
    resources: ["webapps", "webapps/status", "webapps/finalizers"]
    verbs: ["*"]
  - apiGroups: ["apps"]
    resources: ["deployments"]
    verbs: ["*"]
  - apiGroups: ["", "networking.k8s.io"]
    resources: ["services", "secrets", "events", "ingresses"]
    verbs: ["*"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: webapp-operator
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: webapp-operator
subjects:
  - kind: ServiceAccount
    name: webapp-operator
    namespace: deployit-system